{
  "$schema": "https://opencode.ai/config.json",

  "model": "openai/gpt-5.2-codex",
  "small_model": "openai/gpt-5.2-codex",

  "instructions": ["AGENTS.md", "goal.md"],

  "tools": {
    "bash": true,
    "read": true,
    "write": true,
    "edit": true,
    "glob": true,
    "grep": true,
    "list": true,
    "webfetch": false,
    "websearch": false,
    "todoread": true,
    "todowrite": true
  },

  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "edit": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "bash": {
      "*": "allow",
      "rm -rf *": "deny",
      "git push --force *": "deny",
      "git push * --force *": "deny",
      "git reset --hard *": "deny"
    }
  },

  "agent": {
    "manager": {
      "description": "Project manager: reads goals, reviews issues, creates work items, updates memory.",
      "mode": "primary",
      "model": "openai/gpt-5.2-codex",
      "temperature": 0.1,
      "steps": 30
    },
    "swe": {
      "description": "Software engineer: picks issues, implements solutions, reports progress.",
      "mode": "primary",
      "model": "openai/gpt-5.2-codex",
      "temperature": 0.0,
      "steps": 50
    },
    "reviewer": {
      "description": "Code reviewer: reviews PRs, approves and merges good work, requests changes on issues.",
      "mode": "primary",
      "model": "openai/gpt-5.2-codex",
      "temperature": 0.1,
      "steps": 40
    }
  },

  "watcher": {
    "ignore": [".opencode/logs/**", "node_modules/**", ".git/**"]
  }
}
